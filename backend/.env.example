PORT=8080

# football-data.org API key (free tier at football-data.org/client/register)
# Without a key, the app uses built-in test fixtures for local development.
FOOTBALL_DATA_API_KEY=

# Anthropic API key — enables AI-powered starting lineup lookup via Claude + WebSearch
# Without a key, the app falls back to random squad selection.
# Approximate cost: ~$0.001 per lineup fetch (Claude Haiku)
ANTHROPIC_API_KEY=

# Claude model used for lineup fetching (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Allowed CORS origins, comma-separated (default: * for local dev)
# Example for production: CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=
