PORT=8080

# football-data.org API key (free tier at football-data.org/client/register)
# Without a key, the app uses built-in test fixtures for local development.
FOOTBALL_DATA_API_KEY=

# Google Gemini API key — tried FIRST for lineup lookup (free tier with built-in
# google_search grounding). Saves Claude tokens. Get one at aistudio.google.com.
# Without a key, the app skips straight to Claude (if configured).
GEMINI_API_KEY=

# Gemini model used for lineup fetching (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Anthropic API key — FALLBACK lineup lookup via Claude + WebSearch, used only if
# Gemini is unconfigured or fails. Without a key, falls back to squad selection.
# Approximate cost: ~$0.001 per lineup fetch (Claude Haiku)
ANTHROPIC_API_KEY=

# Claude model used for lineup fetching (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Lineup mock mode — set to "true" to bypass ALL external AI calls and serve
# deterministic lineups from testdata/mock_lineups.json. Use for token-free
# local development and testing.
LINEUP_MOCK=

# Allowed CORS origins, comma-separated (default: * for local dev)
# Example for production: CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=
